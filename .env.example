# SwiftAgent Widget – Environment Variables

# ── Vite build-time (baked into the JS bundle) ────────────────────────────────
# URL of the SwiftAgent backend API
VITE_API_BASE_URL=https://api.swiftagents.org

# URL used by the widget to reach the STT/TTS proxy at runtime.
# In Docker, set this to "/" so requests go through the same origin.
VITE_VOICE_API_URL=/

# ── Server runtime (read by server.mjs) ───────────────────────────────────────
# Port the Express server listens on (default: 3002)
PORT=3002

# ElevenLabs credentials (required for STT & TTS endpoints)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
